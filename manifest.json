{
    "manifest_version": 3,
    "name": "Sister Shield",
    "version": "1.0.0",
    "description": "A real-time browser extension that detects suspicious links, blocks risky actions, and provides instant cyber safety support for women and students.",
    "permissions": ["activeTab", "scripting", "storage", "tabs"],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Sister Shield"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["utils.js", "content.js"],
        "run_at": "document_idle"
      }
    ]
  }