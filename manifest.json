{
  "manifest_version": 3,
  "name": "Sister Shield",
  "version": "1.0.0",
  "description": "AI-assisted autonomous browser safety extension that detects suspicious links, phishing-like pages, and risky downloads in real time.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sister Shield"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}